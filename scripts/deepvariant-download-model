#!/bin/bash
# Downloads DeepVariant / DeepTrio models from Google Cloud Storage.
#
# Usage:
#   deepvariant-download-model WGS                 # Download WGS model
#   deepvariant-download-model WGS WES PACBIO      # Download multiple models
#   deepvariant-download-model ALL                  # Download all models
#   deepvariant-download-model WGS --deeptrio      # Download DeepTrio WGS model

set -euo pipefail

VERSION="1.9.0"
DEEPVARIANT_HOME="${DEEPVARIANT_HOME:-$HOME/.deepvariant}"
DEEPTRIO=false

# Parse flags
MODELS=()
for arg in "$@"; do
  case "$arg" in
    --deeptrio) DEEPTRIO=true ;;
    --help|-h)
      echo "Usage: deepvariant-download-model [MODEL_TYPE...] [--deeptrio]"
      echo ""
      echo "Model types: WGS, WES, PACBIO, ONT_R104, HYBRID, MASSEQ, ALL"
      echo ""
      echo "Options:"
      echo "  --deeptrio    Download DeepTrio models instead of DeepVariant"
      echo ""
      echo "Environment:"
      echo "  DEEPVARIANT_HOME    Install directory (default: ~/.deepvariant)"
      exit 0
      ;;
    *) MODELS+=("$(echo "$arg" | tr '[:lower:]' '[:upper:]')") ;;
  esac
done

if [[ ${#MODELS[@]} -eq 0 ]]; then
  echo "ERROR: Specify at least one model type. Use --help for usage."
  exit 1
fi

# Expand ALL
if [[ " ${MODELS[*]} " == *" ALL "* ]]; then
  if [[ "$DEEPTRIO" == true ]]; then
    MODELS=(WGS WES PACBIO ONT)
  else
    MODELS=(WGS WES PACBIO ONT_R104 HYBRID MASSEQ)
  fi
fi

# Bash 3.2-compatible lookup functions (replaces declare -A which requires bash 4+)
# macOS ships with bash 3.2; using case statements avoids the associative array issue.

dv_slug() {
  case "$1" in
    WGS)     echo "wgs" ;;
    WES)     echo "wes" ;;
    PACBIO)  echo "pacbio" ;;
    ONT_R104) echo "ont" ;;
    HYBRID)  echo "hybrid" ;;
    MASSEQ)  echo "masseq" ;;
    *)       echo "" ;;
  esac
}

dv_dir() {
  case "$1" in
    WGS)     echo "wgs" ;;
    WES)     echo "wes" ;;
    PACBIO)  echo "pacbio" ;;
    ONT_R104) echo "ont_r104" ;;
    HYBRID)  echo "hybrid_pacbio_illumina" ;;
    MASSEQ)  echo "masseq" ;;
    *)       echo "" ;;
  esac
}

dt_slug() {
  case "$1" in
    WGS)    echo "wgs" ;;
    WES)    echo "wes" ;;
    PACBIO) echo "pacbio" ;;
    ONT)    echo "ont" ;;
    *)      echo "" ;;
  esac
}

# Returns 0 (true) if the DeepVariant model type has a small model available
dv_has_small_model() {
  case "$1" in
    WGS|PACBIO|ONT_R104) return 0 ;;
    *) return 1 ;;
  esac
}

# Returns 0 (true) if the DeepTrio model type has a small model available
dt_has_small_model() {
  case "$1" in
    WGS|PACBIO|ONT) return 0 ;;
    *) return 1 ;;
  esac
}

download_saved_model() {
  local base_url=$1
  local dest=$2

  mkdir -p "${dest}/variables"

  echo "  Downloading to ${dest}..."
  for f in fingerprint.pb saved_model.pb example_info.json; do
    if curl -fsSL "${base_url}/${f}" -o "${dest}/${f}" 2>/dev/null; then
      :
    else
      echo "    WARNING: ${f} not found (may be optional)"
    fi
  done
  curl -fsSL "${base_url}/variables/variables.data-00000-of-00001" -o "${dest}/variables/variables.data-00000-of-00001"
  curl -fsSL "${base_url}/variables/variables.index" -o "${dest}/variables/variables.index"
}

download_small_model() {
  local base_url=$1
  local dest=$2

  mkdir -p "${dest}/variables"

  echo "  Downloading small model to ${dest}..."
  for f in fingerprint.pb saved_model.pb keras_metadata.pb; do
    if curl -fsSL "${base_url}/${f}" -o "${dest}/${f}" 2>/dev/null; then
      :
    else
      echo "    WARNING: ${f} not found (may be optional)"
    fi
  done
  curl -fsSL "${base_url}/variables/variables.data-00000-of-00001" -o "${dest}/variables/variables.data-00000-of-00001"
  curl -fsSL "${base_url}/variables/variables.index" -o "${dest}/variables/variables.index"
}

GCS_BASE="https://storage.googleapis.com/deepvariant/models"

for model_type in "${MODELS[@]}"; do
  if [[ "$DEEPTRIO" == true ]]; then
    slug="$(dt_slug "$model_type")"
    if [[ -z "$slug" ]]; then
      echo "ERROR: Unknown DeepTrio model type: ${model_type}"
      echo "  Valid types: WGS, WES, PACBIO, ONT"
      exit 1
    fi

    echo "=== Downloading DeepTrio ${model_type} models ==="

    # Child model
    download_saved_model \
      "${GCS_BASE}/DeepTrio/${VERSION}/savedmodels/deeptrio.${slug}_child.savedmodel" \
      "${DEEPVARIANT_HOME}/models/deeptrio/${slug}/child"

    # Parent model
    download_saved_model \
      "${GCS_BASE}/DeepTrio/${VERSION}/savedmodels/deeptrio.${slug}_parent.savedmodel" \
      "${DEEPVARIANT_HOME}/models/deeptrio/${slug}/parent"

    # Small models (if available for this type)
    if dt_has_small_model "$model_type"; then
      download_small_model \
        "${GCS_BASE}/DeepTrio/${VERSION}/smallmodels/deeptrio.${slug}_child.smallmodel" \
        "${DEEPVARIANT_HOME}/smallmodels/deeptrio/${slug}/child"
      download_small_model \
        "${GCS_BASE}/DeepTrio/${VERSION}/smallmodels/deeptrio.${slug}_parent.smallmodel" \
        "${DEEPVARIANT_HOME}/smallmodels/deeptrio/${slug}/parent"
    fi

  else
    slug="$(dv_slug "$model_type")"
    dir_name="$(dv_dir "$model_type")"
    if [[ -z "$slug" ]]; then
      echo "ERROR: Unknown DeepVariant model type: ${model_type}"
      echo "  Valid types: WGS, WES, PACBIO, ONT_R104, HYBRID, MASSEQ"
      exit 1
    fi

    echo "=== Downloading DeepVariant ${model_type} model ==="
    download_saved_model \
      "${GCS_BASE}/DeepVariant/${VERSION}/savedmodels/deepvariant.${slug}.savedmodel" \
      "${DEEPVARIANT_HOME}/models/${dir_name}"

    # Small model (if available for this type)
    if dv_has_small_model "$model_type"; then
      download_small_model \
        "${GCS_BASE}/DeepVariant/${VERSION}/smallmodels/deepvariant.${slug}.smallmodel" \
        "${DEEPVARIANT_HOME}/smallmodels/${dir_name}"
    fi
  fi
done

echo ""
echo "=== Model download complete ==="
echo "Models installed to: ${DEEPVARIANT_HOME}/models/"
